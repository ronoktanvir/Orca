# Orca secrets template. Copy to `.env` (gitignored) and fill in real values.
#   cp .env.example .env   # then edit
# `config.load_dotenv()` loads `.env` into the environment at startup (it never
# overrides values already set in your shell).

# --- W&B / Weave tracing (telemetry §10) ---
# Get a key at https://wandb.ai/authorize. Also run `wandb login` once so the
# key lands in ~/.netrc (telemetry auto-detects it and won't prompt).
WANDB_API_KEY=
WANDB_ENTITY=your-entity        # e.g. your team slug; Weave needs entity/project
WANDB_PROJECT=orca

# --- W&B Inference (models, e.g. GLM-5.1) — OpenAI-compatible endpoint ---
WANDB_INFERENCE_API_KEY=
WANDB_INFERENCE_BASE_URL=https://api.inference.wandb.ai/v1

# --- OpenAI ---
OPENAI_API_KEY=
